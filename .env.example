# Required
TELEGRAM_BOT_TOKEN=123456:replace-me
ALLOWED_TELEGRAM_USER_IDS=123456789
WORKSPACE_ROOT=/absolute/path/to/workspace
DEFAULT_AGENT_COMMAND=codex

# Agent
DEFAULT_AGENT_ADAPTER=codex
AGENT_ENV_ALLOWLIST=
AUTO_START_AGENT=false
DEFAULT_TELEGRAM_CHAT_ID=
AGENT_OUTPUT_MODE=final
FINAL_OUTPUT_IDLE_MS=2500
FINAL_OUTPUT_MAX_WAIT_MS=120000
SUPPRESS_AGENT_TRACE_LINES=true
NOTIFICATION_BLOCK_FILE=/home/you/.local/state/clicourier/muted
MAX_TELEGRAM_CHUNK_CHARS=3500
OUTPUT_FLUSH_INTERVAL_MS=1000
RECENT_OUTPUT_MAX_CHARS=100000

# Files
CAT_MAX_BYTES=65536
SENDFILE_MAX_BYTES=10485760
SCREENSHOT_DIR=
SCREENSHOT_MAX_BYTES=10485760

# Voice
TRANSCRIPTION_BACKEND=none
TRANSCRIPTION_OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
WHISPER_CPP_BINARY=/home/you/.local/share/clicourier/whisper.cpp/main
WHISPER_CPP_MODEL=/home/you/.local/share/clicourier/whisper.cpp/models/ggml-turbo.bin
WHISPER_CPP_FFMPEG_BINARY=ffmpeg
WHISPER_CPP_EXTRA_ARGS=
WHISPER_CPP_TIMEOUT_SECONDS=120
VOICE_MAX_BYTES=25000000

# Conservative security defaults
ALLOW_GROUP_CHATS=false
ALLOW_SENSITIVE_FILE_SEND=false
ALLOW_SCREENSHOT_DIR_OUTSIDE_WORKSPACE=false
UNAUTHORIZED_REPLY_MODE=ignore
